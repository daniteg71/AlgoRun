@prefix ar:   <http://algorun.org/ontology#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .

<http://algorun.org/ontology> a owl:Ontology ;
    rdfs:label "AlgoRun Ontology" ;
    owl:versionInfo "0.4.0" ;
    rdfs:comment """Domain ontology for AlgoRun (AI-LAB 2025/2026): an ontology-driven running DJ. Reasoning chain: heart-rate reading -> effort state -> acoustic target (BPM/energy) -> nearest song. The ontology restricts and validates; it never generates. Vocabularies (EffortState, TrendState, workout goals, phases) match the teammate's sensor code in src/algorun/sensors/.

Scientific basis embedded in the comments below:
- Effort from Heart Rate Reserve: Karvonen, Kentala & Mustala (1957).
- HRmax models: Tanaka et al. (2001) 208-0.7*age; Fox et al. (1971) 220-age.
- Music tempo, arousal and dissociation: Terry & Karageorghis (2011); Karageorghis & Terry (2009).
- Cadence-tempo entrainment (1:1 and half-time): Van Dyck et al. (2015).
- Cadence-change injury limit (<=5%): Heiderscheit et al. (2011).""" .

#################################################################
# Three disjoint cores (IOF-style foundation, course Block 12)
#################################################################

ar:Agent a owl:Class ; rdfs:label "agent" .
ar:Process a owl:Class ; rdfs:label "process" .
ar:InformationEntity a owl:Class ; rdfs:label "information entity" .
ar:Agent owl:disjointWith ar:Process, ar:InformationEntity .
ar:Process owl:disjointWith ar:InformationEntity .

#################################################################
# Domain classes
#################################################################

ar:Runner a owl:Class ; rdfs:subClassOf ar:Agent ;
    rdfs:label "runner" ; skos:altLabel "athlete", "user", "jogger" .

ar:WorkoutSession a owl:Class ; rdfs:subClassOf ar:Process ;
    rdfs:label "workout session" ;
    skos:altLabel "session", "run", "training session" .

ar:TrainingPhase a owl:Class ; rdfs:subClassOf ar:Process ;
    rdfs:label "training phase" ; skos:altLabel "phase", "segment" .
ar:WorkoutSession owl:disjointWith ar:TrainingPhase .

# Sensors: exactly two — accelerometer (-> cadence) and heart-rate sensor.
ar:SensorReading a owl:Class ; rdfs:subClassOf ar:InformationEntity ;
    rdfs:label "sensor reading" ; skos:altLabel "reading", "measurement" ;
    rdfs:subClassOf sosa:Observation .

ar:HeartRateReading a owl:Class ; rdfs:subClassOf ar:SensorReading ;
    rdfs:label "heart rate reading" ;
    skos:altLabel "heart rate", "HR", "pulse", "heartbeat" .

ar:CadenceReading a owl:Class ; rdfs:subClassOf ar:SensorReading ;
    rdfs:label "cadence reading" ;
    skos:altLabel "cadence", "step rate", "steps per minute", "stride rate" ;
    rdfs:comment "Derived from the accelerometer (peak detection on vertical acceleration)." .

[] a owl:AllDisjointClasses ; owl:members ( ar:HeartRateReading ar:CadenceReading ) .

ar:EffortState a owl:Class ; rdfs:subClassOf ar:InformationEntity ;
    rdfs:label "effort state" ;
    rdfs:comment "Intensity level from Heart Rate Reserve, HRR=(HR-rest)/(max-rest) (Karvonen 1957). Four states match physiological_state.py::classify_effort: Low<0.40, Target<0.70, High<0.85, VeryHigh>=0.85." .

ar:TrendState a owl:Class ; rdfs:subClassOf ar:InformationEntity ;
    rdfs:label "trend state" ;
    rdfs:comment "Direction of heart rate over the window (linear slope), matching physiological_state.py::classify_trend." .

ar:WorkoutType a owl:Class ; rdfs:subClassOf ar:InformationEntity ;
    rdfs:label "workout type" ; skos:altLabel "training type", "goal" .

ar:AcousticTarget a owl:Class ; rdfs:subClassOf ar:InformationEntity ;
    rdfs:label "acoustic target" ; skos:altLabel "target", "target point" ;
    rdfs:comment "The BPM/energy/duration region the reasoner produces (not a song). Vector search then finds the nearest track." .

ar:ActionPriority a owl:Class ; rdfs:subClassOf ar:InformationEntity ;
    rdfs:label "action priority" ; skos:altLabel "priority", "severity" ;
    rdfs:comment "Normal -> the playback lock holds (soft transitions); Emergency -> the controller bypasses the lock and cuts the track immediately." .

ar:MusicEntity a owl:Class ; rdfs:subClassOf ar:InformationEntity ;
    rdfs:label "music entity" .
ar:Song a owl:Class ; rdfs:subClassOf ar:MusicEntity ; rdfs:label "song" ;
    skos:altLabel "track", "tune", "piece" .
ar:Genre a owl:Class ; rdfs:subClassOf ar:MusicEntity ; rdfs:label "genre" ;
    skos:altLabel "musical genre", "style" .
ar:Playlist a owl:Class ; rdfs:subClassOf ar:MusicEntity ; rdfs:label "playlist" ;
    skos:altLabel "queue", "mix" .
[] a owl:AllDisjointClasses ; owl:members ( ar:Song ar:Genre ar:Playlist ) .

#################################################################
# Individuals — workout goals & phases match the teammate's code
#################################################################

ar:Easy a ar:WorkoutType ; rdfs:label "easy" ;
    skos:altLabel "easy run", "recovery run", "long run", "endurance" .
ar:Moderate a ar:WorkoutType ; rdfs:label "moderate" ;
    skos:altLabel "tempo", "threshold", "moderate run" .
ar:Interval a ar:WorkoutType ; rdfs:label "interval" ;
    skos:altLabel "intervals", "HIIT", "speed work" .

ar:WarmUp a ar:TrainingPhase ; rdfs:label "warmup" ; skos:altLabel "warm-up", "warm up" .
ar:Steady a ar:TrainingPhase ; rdfs:label "steady" ; skos:altLabel "steady state", "cruise" .
ar:Hard a ar:TrainingPhase ; rdfs:label "hard" ; skos:altLabel "surge", "push", "sprint" .
ar:Recovery a ar:TrainingPhase ; rdfs:label "recovery" ; skos:altLabel "rest", "float" .

# Effort states — HRR thresholds from Karvonen (1957)
ar:LowEffort a ar:EffortState ; rdfs:label "LowEffort" ;
    skos:altLabel "very light", "easy effort" ;
    rdfs:comment "HRR < 0.40." .
ar:TargetEffort a ar:EffortState ; rdfs:label "TargetEffort" ;
    skos:altLabel "moderate effort", "aerobic" ;
    rdfs:comment "0.40 <= HRR < 0.70." .
ar:HighEffort a ar:EffortState ; rdfs:label "HighEffort" ;
    skos:altLabel "hard effort", "threshold" ;
    rdfs:comment "0.70 <= HRR < 0.85." .
ar:VeryHighEffort a ar:EffortState ; rdfs:label "VeryHighEffort" ;
    skos:altLabel "maximal effort", "red line" ;
    rdfs:comment "HRR >= 0.85." .

# Trend states
ar:Increasing a ar:TrendState ; rdfs:label "Increasing" .
ar:Stable a ar:TrendState ; rdfs:label "Stable" .
ar:Decreasing a ar:TrendState ; rdfs:label "Decreasing" .

# Action priorities
ar:NormalPriority a ar:ActionPriority ; rdfs:label "normal priority" ; skos:altLabel "normal", "routine" .
ar:EmergencyPriority a ar:ActionPriority ; rdfs:label "emergency priority" ; skos:altLabel "emergency", "critical", "panic" .

#################################################################
# Acoustic targets per effort state (BPM/energy from the training-
# zone x music evidence). At low effort optimise arousal (calm, the
# foot entrains in half-time); at high effort optimise 1:1 beat
# synchronization. Sources: Terry & Karageorghis (2011); Van Dyck
# et al. (2015); practitioner BPM guides.
#################################################################

ar:RecoveryTarget a ar:AcousticTarget ; rdfs:label "recovery target" ;
    ar:targetBpmMin 90 ; ar:targetBpmMax 110 ;
    ar:targetEnergyMin 0.1 ; ar:targetEnergyMax 0.3 ;
    rdfs:comment "LowEffort: ambient, chill-out, downtempo; slow tempo speeds HR/lactate recovery." .
ar:EasyTarget a ar:AcousticTarget ; rdfs:label "easy target" ;
    ar:targetBpmMin 120 ; ar:targetBpmMax 130 ;
    ar:targetEnergyMin 0.4 ; ar:targetEnergyMax 0.6 ;
    ar:targetDurationMinMs 360000 ;
    rdfs:comment "TargetEffort: deep house, pop; long tracks (>=6 min) for a steady flow." .
ar:ThresholdTarget a ar:AcousticTarget ; rdfs:label "threshold target" ;
    ar:targetBpmMin 130 ; ar:targetBpmMax 150 ;
    ar:targetEnergyMin 0.6 ; ar:targetEnergyMax 0.8 ;
    rdfs:comment "HighEffort: techno, drum & bass; steady driving 1:1 beat." .
ar:IntervalTarget a ar:AcousticTarget ; rdfs:label "interval target" ;
    ar:targetBpmMin 150 ; ar:targetBpmMax 180 ;
    ar:targetEnergyMin 0.8 ; ar:targetEnergyMax 1.0 ;
    ar:targetDurationMaxMs 240000 ;
    rdfs:comment "VeryHighEffort: hard techno, metal, dubstep; short tracks (<=4 min) for work bouts." .

# effort state -> prescribed acoustic target
ar:LowEffort      ar:prescribesTarget ar:RecoveryTarget .
ar:TargetEffort   ar:prescribesTarget ar:EasyTarget .
ar:HighEffort     ar:prescribesTarget ar:ThresholdTarget .
ar:VeryHighEffort ar:prescribesTarget ar:IntervalTarget .

# phase -> default target effort
ar:WarmUp   ar:targetsEffort ar:LowEffort .
ar:Steady   ar:targetsEffort ar:TargetEffort .
ar:Hard     ar:targetsEffort ar:VeryHighEffort .
ar:Recovery ar:targetsEffort ar:LowEffort .

#################################################################
# Object properties (forward + inverse; domain/range = the gate)
#################################################################

ar:performsSession a owl:ObjectProperty ; rdfs:domain ar:Runner ; rdfs:range ar:WorkoutSession ;
    rdfs:label "performs session" ; skos:altLabel "performs", "completes", "does", "runs" ;
    owl:inverseOf ar:performedBy .
ar:performedBy a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:Runner ;
    rdfs:label "performed by" .

ar:hasWorkoutType a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:WorkoutType ;
    rdfs:label "has workout type" ; skos:altLabel "is a", "typed as", "planned as" ;
    owl:inverseOf ar:isWorkoutTypeOf .
ar:isWorkoutTypeOf a owl:ObjectProperty ; rdfs:domain ar:WorkoutType ; rdfs:range ar:WorkoutSession ;
    rdfs:label "is workout type of" .

ar:hasPhase a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:TrainingPhase ;
    rdfs:label "has phase" ; skos:altLabel "includes phase", "goes through" ;
    owl:inverseOf ar:phaseOf .
ar:phaseOf a owl:ObjectProperty ; rdfs:domain ar:TrainingPhase ; rdfs:range ar:WorkoutSession ;
    rdfs:label "phase of" .

ar:nextPhase a owl:ObjectProperty ; rdfs:domain ar:TrainingPhase ; rdfs:range ar:TrainingPhase ;
    rdfs:label "next phase" ; skos:altLabel "followed by", "then" ;
    owl:inverseOf ar:previousPhase .
ar:previousPhase a owl:ObjectProperty ; rdfs:domain ar:TrainingPhase ; rdfs:range ar:TrainingPhase ;
    rdfs:label "previous phase" .

ar:recordsReading a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:SensorReading ;
    rdfs:label "records reading" ; skos:altLabel "records", "logs", "registers", "measures" ;
    owl:inverseOf ar:recordedIn .
ar:recordedIn a owl:ObjectProperty ; rdfs:domain ar:SensorReading ; rdfs:range ar:WorkoutSession ;
    rdfs:label "recorded in" .

ar:hasEffortState a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:EffortState ;
    rdfs:label "has effort state" ; skos:altLabel "at effort", "in effort" ;
    owl:inverseOf ar:effortStateOf .
ar:effortStateOf a owl:ObjectProperty ; rdfs:domain ar:EffortState ; rdfs:range ar:WorkoutSession ;
    rdfs:label "effort state of" .

ar:hasTrend a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:TrendState ;
    rdfs:label "has trend" ; skos:altLabel "trending" ;
    owl:inverseOf ar:trendOf .
ar:trendOf a owl:ObjectProperty ; rdfs:domain ar:TrendState ; rdfs:range ar:WorkoutSession ;
    rdfs:label "trend of" .

ar:targetsEffort a owl:ObjectProperty ; rdfs:domain ar:TrainingPhase ; rdfs:range ar:EffortState ;
    rdfs:label "targets effort" ; skos:altLabel "targets", "aims for" ;
    owl:inverseOf ar:targetedByPhase .
ar:targetedByPhase a owl:ObjectProperty ; rdfs:domain ar:EffortState ; rdfs:range ar:TrainingPhase ;
    rdfs:label "targeted by phase" .

ar:prescribesTarget a owl:ObjectProperty ; rdfs:domain ar:EffortState ; rdfs:range ar:AcousticTarget ;
    rdfs:label "prescribes target" ; skos:altLabel "prescribes", "calls for" ;
    rdfs:comment "Physiological mapping: an effort state prescribes an acoustic target. Chain: phase -> targetsEffort -> effort -> prescribesTarget -> target." ;
    owl:inverseOf ar:prescribedFor .
ar:prescribedFor a owl:ObjectProperty ; rdfs:domain ar:AcousticTarget ; rdfs:range ar:EffortState ;
    rdfs:label "prescribed for" .

ar:suitsPhase a owl:ObjectProperty ; rdfs:domain ar:Song ; rdfs:range ar:TrainingPhase ;
    rdfs:label "suits phase" ; skos:altLabel "suits", "fits", "is good for" ;
    owl:inverseOf ar:suitedBySong .
ar:suitedBySong a owl:ObjectProperty ; rdfs:domain ar:TrainingPhase ; rdfs:range ar:Song ;
    rdfs:label "suited by song" .

ar:matchesEffort a owl:ObjectProperty ; rdfs:domain ar:Song ; rdfs:range ar:EffortState ;
    rdfs:label "matches effort" ; skos:altLabel "matches", "pairs with" ;
    owl:inverseOf ar:matchedBySong .
ar:matchedBySong a owl:ObjectProperty ; rdfs:domain ar:EffortState ; rdfs:range ar:Song ;
    rdfs:label "matched by song" .

ar:hasGenre a owl:ObjectProperty ; rdfs:domain ar:Song ; rdfs:range ar:Genre ;
    rdfs:label "has genre" ; skos:altLabel "belongs to genre", "classified as" ;
    owl:inverseOf ar:isGenreOf .
ar:isGenreOf a owl:ObjectProperty ; rdfs:domain ar:Genre ; rdfs:range ar:Song ;
    rdfs:label "is genre of" .

ar:prefersGenre a owl:ObjectProperty ; rdfs:domain ar:Runner ; rdfs:range ar:Genre ;
    rdfs:label "prefers genre" ; skos:altLabel "likes", "prefers", "enjoys" ;
    owl:inverseOf ar:preferredBy .
ar:preferredBy a owl:ObjectProperty ; rdfs:domain ar:Genre ; rdfs:range ar:Runner ;
    rdfs:label "preferred by" .

ar:includedIn a owl:ObjectProperty ; rdfs:domain ar:Song ; rdfs:range ar:Playlist ;
    rdfs:label "included in" ; skos:altLabel "added to", "queued in", "part of" ;
    owl:inverseOf ar:containsSong .
ar:containsSong a owl:ObjectProperty ; rdfs:domain ar:Playlist ; rdfs:range ar:Song ;
    rdfs:label "contains song" ; skos:altLabel "contains", "features" .

ar:builtForSession a owl:ObjectProperty ; rdfs:domain ar:Playlist ; rdfs:range ar:WorkoutSession ;
    rdfs:label "built for session" ; skos:altLabel "built for", "created for" ;
    owl:inverseOf ar:servedByPlaylist .
ar:servedByPlaylist a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:Playlist ;
    rdfs:label "served by playlist" .

ar:hasActionPriority a owl:ObjectProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range ar:ActionPriority ;
    rdfs:label "has action priority" ; skos:altLabel "escalated to", "flagged as" ;
    owl:inverseOf ar:priorityOf .
ar:priorityOf a owl:ObjectProperty ; rdfs:domain ar:ActionPriority ; rdfs:range ar:WorkoutSession ;
    rdfs:label "priority of" .

#################################################################
# Data properties
#################################################################

ar:heartRateBpm a owl:DatatypeProperty ; rdfs:domain ar:HeartRateReading ; rdfs:range xsd:decimal ;
    rdfs:label "heart rate bpm" ; skos:altLabel "bpm", "beats per minute" .
ar:cadenceSpm a owl:DatatypeProperty ; rdfs:domain ar:CadenceReading ; rdfs:range xsd:decimal ;
    rdfs:label "cadence spm" ; skos:altLabel "spm", "steps per minute" .
ar:timestamp a owl:DatatypeProperty ; rdfs:domain ar:SensorReading ; rdfs:range xsd:dateTime ;
    rdfs:label "timestamp" .
ar:durationMinutes a owl:DatatypeProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range xsd:decimal ;
    rdfs:label "duration minutes" .

# Runner health baselines (Tanaka/Fox HRmax; Karvonen HRR)
ar:maxHeartRateBpm a owl:DatatypeProperty ; rdfs:domain ar:Runner ; rdfs:range xsd:decimal ;
    rdfs:label "max heart rate bpm" ;
    rdfs:comment "Estimated HRmax (Tanaka 208-0.7*age; Fox 220-age)." .
ar:restingHeartRateBpm a owl:DatatypeProperty ; rdfs:domain ar:Runner ; rdfs:range xsd:decimal ;
    rdfs:label "resting heart rate bpm" .
ar:safeMaxHeartRateBpm a owl:DatatypeProperty ; rdfs:domain ar:Runner ; rdfs:range xsd:decimal ;
    rdfs:label "safe max heart rate bpm" ;
    rdfs:comment "Emergency line (default 93% HRmax). Above it the system forces a relaxing target." .

# Decision-time stamps on a session (used by the SHACL safety gate)
ar:currentCadenceSpm a owl:DatatypeProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range xsd:decimal ;
    rdfs:label "current cadence spm" .
ar:currentHeartRateBpm a owl:DatatypeProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range xsd:decimal ;
    rdfs:label "current heart rate bpm" .
ar:appliedTargetBpm a owl:DatatypeProperty ; rdfs:domain ar:WorkoutSession ; rdfs:range xsd:decimal ;
    rdfs:label "applied target bpm" ;
    rdfs:comment "The BPM about to be applied; checked by the safety constraints before the song switch." .

# Song attributes (Spotify-like)
ar:bpmValue a owl:DatatypeProperty ; rdfs:domain ar:Song ; rdfs:range xsd:decimal ;
    rdfs:label "bpm value" ; skos:altLabel "tempo", "BPM" .
ar:energyValue a owl:DatatypeProperty ; rdfs:domain ar:Song ; rdfs:range xsd:decimal ;
    rdfs:label "energy value" ; skos:altLabel "energy" .
ar:valenceValue a owl:DatatypeProperty ; rdfs:domain ar:Song ; rdfs:range xsd:decimal ;
    rdfs:label "valence value" ; skos:altLabel "valence", "positivity" .
ar:trackDurationMs a owl:DatatypeProperty ; rdfs:domain ar:Song ; rdfs:range xsd:integer ;
    rdfs:label "track duration ms" ; skos:altLabel "duration", "length" .
ar:songTitle a owl:DatatypeProperty ; rdfs:domain ar:Song ; rdfs:range xsd:string ; rdfs:label "song title" .
ar:artistName a owl:DatatypeProperty ; rdfs:domain ar:Song ; rdfs:range xsd:string ; rdfs:label "artist name" .

# Acoustic-target ranges
ar:targetBpmMin a owl:DatatypeProperty ; rdfs:domain ar:AcousticTarget ; rdfs:range xsd:decimal ; rdfs:label "target bpm min" .
ar:targetBpmMax a owl:DatatypeProperty ; rdfs:domain ar:AcousticTarget ; rdfs:range xsd:decimal ; rdfs:label "target bpm max" .
ar:targetEnergyMin a owl:DatatypeProperty ; rdfs:domain ar:AcousticTarget ; rdfs:range xsd:decimal ; rdfs:label "target energy min" .
ar:targetEnergyMax a owl:DatatypeProperty ; rdfs:domain ar:AcousticTarget ; rdfs:range xsd:decimal ; rdfs:label "target energy max" .
ar:targetDurationMinMs a owl:DatatypeProperty ; rdfs:domain ar:AcousticTarget ; rdfs:range xsd:integer ; rdfs:label "target duration min ms" .
ar:targetDurationMaxMs a owl:DatatypeProperty ; rdfs:domain ar:AcousticTarget ; rdfs:range xsd:integer ; rdfs:label "target duration max ms" .
