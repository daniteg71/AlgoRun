#################################################################
# Health / safety constraints (v0.3) — the "life-saving" rules.
# SPARQL-based so they can compare two values on the same node. The
# recommender stamps ar:currentCadenceSpm / ar:currentHeartRateBpm /
# ar:appliedTargetBpm / ar:forRunner on the session at decision time.
#################################################################

# Cadence guard (injury prevention): the applied target BPM must not
# exceed the current cadence by more than 5% — never jump a runner from
# 140 spm straight to a 180 bpm track (Heiderscheit et al. 2011).
ar:CadenceStepShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:appliedTargetBpm ;
    sh:sparql [
        sh:message "Unsafe cadence jump: applied target BPM exceeds current cadence by more than 5%." ;
        sh:select """
            SELECT $this ?b ?c WHERE {
                $this <http://algorun.org/ontology#appliedTargetBpm> ?b ;
                      <http://algorun.org/ontology#currentCadenceSpm> ?c .
                FILTER (?b > 1.05 * ?c)
            }""" ] .

# Critical heart-rate guard: an energetic target (BPM > 140) is forbidden
# once the runner is at or above their safe max HR — the system must force
# a relaxing target instead (Terry & Karageorghis 2011: fast music raises
# HR and arousal).
ar:CriticalHeartRateShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:currentHeartRateBpm ;
    sh:sparql [
        sh:message "Critical heart rate: an energetic target (BPM > 140) is forbidden at or above the runner's safe max HR." ;
        sh:select """
            SELECT $this ?hr ?b WHERE {
                $this <http://algorun.org/ontology#currentHeartRateBpm> ?hr ;
                      <http://algorun.org/ontology#appliedTargetBpm> ?b ;
                      <http://algorun.org/ontology#performedBy> ?r .
                ?r <http://algorun.org/ontology#safeMaxHeartRateBpm> ?safe .
                FILTER (?hr >= ?safe && ?b > 140)
            }""" ] .

### hasActionPriority (WorkoutSession → ActionPriority)

ar:HasActionPrioritySubjectShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:hasActionPriority ;
    sh:class ar:WorkoutSession ;
    sh:message "Domain violation: subject of ar:hasActionPriority must be an ar:WorkoutSession." .

ar:HasActionPriorityObjectShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:hasActionPriority ;
    sh:property [
        sh:path ar:hasActionPriority ;
        sh:class ar:ActionPriority ;
        sh:message "Range violation: object of ar:hasActionPriority must be an ar:ActionPriority." ;
    ] .

# Emergency guard: a session flagged EmergencyPriority must not carry an
# energetic applied target — the controller must cut to a relaxing track,
# bypassing the playback lock (dual-speed architecture).
ar:EmergencyTargetShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:hasActionPriority ;
    sh:sparql [
        sh:message "Emergency state: applied target BPM must be ≤ 140 when the session is flagged EmergencyPriority." ;
        sh:select """
            SELECT $this ?b WHERE {
                $this <http://algorun.org/ontology#hasActionPriority>
                      <http://algorun.org/ontology#EmergencyPriority> ;
                      <http://algorun.org/ontology#appliedTargetBpm> ?b .
                FILTER (?b > 140)
            }""" ] .

#################################################################
# Value constraints on data properties
#################################################################

ar:HeartRateValueShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:heartRateBpm ;
    sh:class ar:HeartRateReading ;
    sh:property [
        sh:path ar:heartRateBpm ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 25 ;
        sh:maxInclusive 240 ;
        sh:message "ar:heartRateBpm must be a decimal in [25, 240] on an ar:HeartRateReading." ;
    ] .

ar:SongBpmShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:bpmValue ;
    sh:class ar:Song ;
    sh:property [
        sh:path ar:bpmValue ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 30 ;
        sh:maxInclusive 260 ;
        sh:message "ar:bpmValue must be a decimal in [30, 260] on an ar:Song." ;
    ] .

ar:EnergyShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:energyValue ;
    sh:class ar:Song ;
    sh:property [
        sh:path ar:energyValue ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "ar:energyValue must be a decimal in [0, 1] on an ar:Song." ;
    ] .

ar:ValenceShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:valenceValue ;
    sh:class ar:Song ;
    sh:property [
        sh:path ar:valenceValue ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "ar:valenceValue must be a decimal in [0, 1] on an ar:Song." ;
    ] .

ar:CadenceShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:cadenceSpm ;
    sh:class ar:CadenceReading ;
    sh:property [
        sh:path ar:cadenceSpm ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 40 ;
        sh:maxInclusive 260 ;
        sh:message "ar:cadenceSpm must be a decimal in [40, 260] on an ar:CadenceReading." ;
    ] .

ar:PaceShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:paceMinPerKm ;
    sh:class ar:PaceReading ;
    sh:property [
        sh:path ar:paceMinPerKm ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 2.0 ;
        sh:maxInclusive 20.0 ;
        sh:message "ar:paceMinPerKm must be a decimal in [2, 20] on an ar:PaceReading." ;
    ] .
