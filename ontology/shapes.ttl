@prefix ar:  <http://algorun.org/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# SHACL Constraint Gate — mirrors every domain/range pair of the
# ontology. A triple that violates any shape here is rejected
# BEFORE it can enter the RDF Knowledge Graph (Rule 3/Rule 1 of
# GUIDELINES.md: "SHACL enforces truth").
#
# Pattern per object property P(D → R):
#   - subject shape:  every subject of P must be an instance of D
#   - object shape:   every value  of P must be an instance of R
#################################################################

### performsSession (Runner → WorkoutSession)

ar:PerformsSessionSubjectShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:performsSession ;
    sh:class ar:Runner ;
    sh:message "Domain violation: subject of ar:performsSession must be an ar:Runner." .

ar:PerformsSessionObjectShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:performsSession ;
    sh:property [
        sh:path ar:performsSession ;
        sh:class ar:WorkoutSession ;
        sh:message "Range violation: object of ar:performsSession must be an ar:WorkoutSession." ;
    ] .

