#################################################################
# Value constraints on data properties
#################################################################

ar:HeartRateValueShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:heartRateBpm ;
    sh:class ar:HeartRateReading ;
    sh:property [
        sh:path ar:heartRateBpm ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 25 ;
        sh:maxInclusive 240 ;
        sh:message "ar:heartRateBpm must be a decimal in [25, 240] on an ar:HeartRateReading." ;
    ] .

ar:SongBpmShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:bpmValue ;
    sh:class ar:Song ;
    sh:property [
        sh:path ar:bpmValue ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 30 ;
        sh:maxInclusive 260 ;
        sh:message "ar:bpmValue must be a decimal in [30, 260] on an ar:Song." ;
    ] .

ar:EnergyShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:energyValue ;
    sh:class ar:Song ;
    sh:property [
        sh:path ar:energyValue ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "ar:energyValue must be a decimal in [0, 1] on an ar:Song." ;
    ] .

ar:ValenceShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:valenceValue ;
    sh:class ar:Song ;
    sh:property [
        sh:path ar:valenceValue ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "ar:valenceValue must be a decimal in [0, 1] on an ar:Song." ;
    ] .

ar:CadenceShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:cadenceSpm ;
    sh:class ar:CadenceReading ;
    sh:property [
        sh:path ar:cadenceSpm ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 40 ;
        sh:maxInclusive 260 ;
        sh:message "ar:cadenceSpm must be a decimal in [40, 260] on an ar:CadenceReading." ;
    ] .

ar:PaceShape a sh:NodeShape ;
    sh:targetSubjectsOf ar:paceMinPerKm ;
    sh:class ar:PaceReading ;
    sh:property [
        sh:path ar:paceMinPerKm ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 2.0 ;
        sh:maxInclusive 20.0 ;
        sh:message "ar:paceMinPerKm must be a decimal in [2, 20] on an ar:PaceReading." ;
    ] .
