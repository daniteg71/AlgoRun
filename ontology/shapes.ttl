@prefix ar:  <http://algorun.org/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# SHACL Constraint Gate — one shape per object property enforces
# its domain (subject class) and range (object class). Runs with
# inference OFF, so a violating triple is rejected, not classified
# away. Nothing enters the Knowledge Graph without passing here.
#################################################################

ar:PerformsSessionShape a sh:NodeShape ; sh:targetSubjectsOf ar:performsSession ;
    sh:class ar:Runner ;
    sh:property [ sh:path ar:performsSession ; sh:class ar:WorkoutSession ;
        sh:message "ar:performsSession must go Runner -> WorkoutSession." ] .

ar:HasWorkoutTypeShape a sh:NodeShape ; sh:targetSubjectsOf ar:hasWorkoutType ;
    sh:class ar:WorkoutSession ;
    sh:property [ sh:path ar:hasWorkoutType ; sh:class ar:WorkoutType ;
        sh:message "ar:hasWorkoutType must go WorkoutSession -> WorkoutType." ] .

ar:HasPhaseShape a sh:NodeShape ; sh:targetSubjectsOf ar:hasPhase ;
    sh:class ar:WorkoutSession ;
    sh:property [ sh:path ar:hasPhase ; sh:class ar:TrainingPhase ;
        sh:message "ar:hasPhase must go WorkoutSession -> TrainingPhase." ] .

ar:RecordsReadingShape a sh:NodeShape ; sh:targetSubjectsOf ar:recordsReading ;
    sh:class ar:WorkoutSession ;
    sh:property [ sh:path ar:recordsReading ; sh:class ar:SensorReading ;
        sh:message "ar:recordsReading must go WorkoutSession -> SensorReading." ] .

ar:HasEffortStateShape a sh:NodeShape ; sh:targetSubjectsOf ar:hasEffortState ;
    sh:class ar:WorkoutSession ;
    sh:property [ sh:path ar:hasEffortState ; sh:class ar:EffortState ;
        sh:message "ar:hasEffortState must go WorkoutSession -> EffortState." ] .

ar:HasTrendShape a sh:NodeShape ; sh:targetSubjectsOf ar:hasTrend ;
    sh:class ar:WorkoutSession ;
    sh:property [ sh:path ar:hasTrend ; sh:class ar:TrendState ;
        sh:message "ar:hasTrend must go WorkoutSession -> TrendState." ] .

ar:TargetsEffortShape a sh:NodeShape ; sh:targetSubjectsOf ar:targetsEffort ;
    sh:class ar:TrainingPhase ;
    sh:property [ sh:path ar:targetsEffort ; sh:class ar:EffortState ;
        sh:message "ar:targetsEffort must go TrainingPhase -> EffortState." ] .

ar:PrescribesTargetShape a sh:NodeShape ; sh:targetSubjectsOf ar:prescribesTarget ;
    sh:class ar:EffortState ;
    sh:property [ sh:path ar:prescribesTarget ; sh:class ar:AcousticTarget ;
        sh:message "ar:prescribesTarget must go EffortState -> AcousticTarget." ] .

ar:SuitsPhaseShape a sh:NodeShape ; sh:targetSubjectsOf ar:suitsPhase ;
    sh:class ar:Song ;
    sh:property [ sh:path ar:suitsPhase ; sh:class ar:TrainingPhase ;
        sh:message "ar:suitsPhase must go Song -> TrainingPhase." ] .

ar:MatchesEffortShape a sh:NodeShape ; sh:targetSubjectsOf ar:matchesEffort ;
    sh:class ar:Song ;
    sh:property [ sh:path ar:matchesEffort ; sh:class ar:EffortState ;
        sh:message "ar:matchesEffort must go Song -> EffortState." ] .

ar:HasGenreShape a sh:NodeShape ; sh:targetSubjectsOf ar:hasGenre ;
    sh:class ar:Song ;
    sh:property [ sh:path ar:hasGenre ; sh:class ar:Genre ;
        sh:message "ar:hasGenre must go Song -> Genre." ] .

ar:PrefersGenreShape a sh:NodeShape ; sh:targetSubjectsOf ar:prefersGenre ;
    sh:class ar:Runner ;
    sh:property [ sh:path ar:prefersGenre ; sh:class ar:Genre ;
        sh:message "ar:prefersGenre must go Runner -> Genre." ] .

ar:IncludedInShape a sh:NodeShape ; sh:targetSubjectsOf ar:includedIn ;
    sh:class ar:Song ;
    sh:property [ sh:path ar:includedIn ; sh:class ar:Playlist ;
        sh:message "ar:includedIn must go Song -> Playlist." ] .

ar:ContainsSongShape a sh:NodeShape ; sh:targetSubjectsOf ar:containsSong ;
    sh:class ar:Playlist ;
    sh:property [ sh:path ar:containsSong ; sh:class ar:Song ;
        sh:message "ar:containsSong must go Playlist -> Song." ] .

ar:BuiltForSessionShape a sh:NodeShape ; sh:targetSubjectsOf ar:builtForSession ;
    sh:class ar:Playlist ;
    sh:property [ sh:path ar:builtForSession ; sh:class ar:WorkoutSession ;
        sh:message "ar:builtForSession must go Playlist -> WorkoutSession." ] .

ar:HasActionPriorityShape a sh:NodeShape ; sh:targetSubjectsOf ar:hasActionPriority ;
    sh:class ar:WorkoutSession ;
    sh:property [ sh:path ar:hasActionPriority ; sh:class ar:ActionPriority ;
        sh:message "ar:hasActionPriority must go WorkoutSession -> ActionPriority." ] .

#################################################################
# Value bounds on measured quantities
#################################################################

ar:HeartRateValueShape a sh:NodeShape ; sh:targetSubjectsOf ar:heartRateBpm ;
    sh:property [ sh:path ar:heartRateBpm ; sh:datatype xsd:decimal ;
        sh:minInclusive 25 ; sh:maxInclusive 240 ;
        sh:message "ar:heartRateBpm must be in [25, 240]." ] .

ar:CadenceValueShape a sh:NodeShape ; sh:targetSubjectsOf ar:cadenceSpm ;
    sh:property [ sh:path ar:cadenceSpm ; sh:datatype xsd:decimal ;
        sh:minInclusive 40 ; sh:maxInclusive 260 ;
        sh:message "ar:cadenceSpm must be in [40, 260]." ] .

ar:SongBpmShape a sh:NodeShape ; sh:targetSubjectsOf ar:bpmValue ;
    sh:property [ sh:path ar:bpmValue ; sh:datatype xsd:decimal ;
        sh:minInclusive 30 ; sh:maxInclusive 260 ;
        sh:message "ar:bpmValue must be in [30, 260]." ] .

ar:EnergyShape a sh:NodeShape ; sh:targetSubjectsOf ar:energyValue ;
    sh:property [ sh:path ar:energyValue ; sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ; sh:maxInclusive 1.0 ;
        sh:message "ar:energyValue must be in [0, 1]." ] .
